# ─────────────────────────────────────────────────────────────
# Superlikers WhatsApp Ticket Bot — variables de entorno (n8n)
# Copiá a .env y completá. NUNCA commitees el .env real.
# Los valores reales viven en el sistema de credenciales de n8n;
# estas vars son para la URL base y referencias no secretas.
# ─────────────────────────────────────────────────────────────

# API Superlikers (entorno de pruebas / labs)
BASE_URL=https://api.superlikerslabs.com/v1
CAMPAIGN=3z

# El api_key NO va en el body (mala práctica verificada). La
# autenticación es Bearer vía credencial n8n [SL]: Jafet (httpBearerAuth).
# Solo se documenta acá para el equipo; el secreto vive en n8n.
# API_KEY=__set_in_n8n_credential__

# Twilio (WhatsApp Business API) — usados por el nodo que descarga
# el media (MediaUrl0 requiere Basic auth con SID/Token).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+17876639222
