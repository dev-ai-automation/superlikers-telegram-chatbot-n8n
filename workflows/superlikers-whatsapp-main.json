        "jsCode": "const b = $json.body || $json;\nconst fromRaw = b.From || '';\nconst phone = String(fromRaw).replace('whatsapp:', '').replace(/\\D/g, '');\nconst numMedia = Number(b.NumMedia || 0);\nreturn {\n  phone,\n  fromRaw,\n  text: b.Body || '',\n  hasMedia: numMedia > 0,\n  mediaUrl: b.MediaUrl0 || '',\n  mediaType: b.MediaContentType0 || ''\n};"
      }
