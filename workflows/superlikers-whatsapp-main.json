      "position": [1100, 400],
      "parameters": {
        "mode": "runOnceForEachItem",
        "language": "javaScript",
        "jsCode": "const sess = $json && $json.phone ? $json : {};\nconst inp = $('Normalize Twilio Input').item.json;\nconst currentStep = Number(sess.currentStep || 1);\nconst stepMap = { 1: 'phone', 3: 'name', 4: 'email', 5: 'confirm', 6: 'photo', 9: 'done' };\nlet state = stepMap[currentStep] || 'phone';\nif (state === 'done' && inp.hasMedia) state = 'photo';\nreturn {\n  phone: inp.phone,\n  fromRaw: inp.fromRaw,\n  text: inp.text,\n  hasMedia: inp.hasMedia,\n  mediaUrl: inp.mediaUrl,\n  currentStep,\n  state,\n  distinctId: sess.distinctId || '',\n  name: sess.name || '',\n  email: sess.email || '',\n  photoActivityId: sess.photoActivityId || ''\n};"
      }
